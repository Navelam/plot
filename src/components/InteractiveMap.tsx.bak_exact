import React from 'react';
import type { Plot } from '../data/plots';

interface InteractiveMapProps {
  plots: Plot[];
  onSelectPlot: (plot: Plot) => void;
  selectedPlot: Plot | null;
}

export const InteractiveMap: React.FC<InteractiveMapProps> = ({
  plots,
  onSelectPlot,
  selectedPlot
}) => {

  const adjustRow1X = (plotId: string, x: number): number => {
    const numId = parseInt(plotId, 10);
    const isR7Block = (numId >= 145 && numId <= 157);
    const isColumn1 = (plotId === 'EB' || plotId === '167' || plotId === '166');
    const isColumn2 = (plotId === 'LB' || plotId === '162' || plotId === '163' || plotId === '164' || plotId === '165');
    const isLeftPlots = (plotId === '168' || plotId === '169');

    if (isLeftPlots) {
      return 520 - (520 - x) * 0.8;
    } else if (isColumn1 || isColumn2) {
      return 640 + (x - 640) * (90 / 130);
    } else if (isR7Block) {
      return 980 + (x - 980) * 0.75;
    }
    return x;
  };

  const adjustRow1Points = (plotId: string, pointsStr: string): string => {
    return pointsStr.trim().split(/\s+/).map(p => {
      const [xStr, yStr] = p.split(',');
      const x = Number(xStr);
      const y = Number(yStr);
      if (isNaN(x) || isNaN(y)) return p;
      return `${adjustRow1X(plotId, x).toFixed(2)},${y}`;
    }).join(' ');
  };

  // Helper to compute plot coordinates dynamically matching the PDF layout structure
  const getPlotCoords = (plotId: string): { x: number; y: number; w: number; h: number } | null => {
    const getBaseCoords = (): { x: number; y: number; w: number; h: number } | null => {
      const numId = parseInt(plotId, 10);

      // Block L1 (Plots 1 to 7)
      if (numId === 1) {
        return { x: 230.7, y: 840, w: 49.3, h: 90 };
      }
      if (numId >= 2 && numId <= 7) {
        return { x: 280 + (numId - 2) * 40, y: 840, w: 40, h: 90 };
      }
      // Block R1 (Plots 8, 9)
      if (numId === 8) return { x: 640, y: 840, w: 46, h: 55.3 };
      if (numId === 9) return { x: 686, y: 840, w: 35.7, h: 54 };

      // Block R2 (Plots 10 to 15)
      if (numId === 15) return { x: 640, y: 660, w: 40, h: 40 };
      if (numId === 14) return { x: 680, y: 660, w: 40, h: 40 };
      if (numId === 13) return { x: 720, y: 660, w: 40, h: 40 };
      if (numId === 12) return { x: 760, y: 660, w: 30.7, h: 40 };
      if (numId === 11) return { x: 790.7, y: 660, w: 30.7, h: 40 };
      if (numId === 10) return { x: 821.3, y: 660, w: 30.7, h: 40 };

      // Block L2 (Plots 16 to 31)
      if (numId >= 16 && numId <= 21) {
        return { x: 480 - (numId - 16) * 40, y: 660, w: 40, h: 40 };
      }
      if (numId === 22) {
        return { x: 248, y: 660, w: 32, h: 40 };
      }
      if (numId === 23) {
        return { x: 220, y: 660, w: 28, h: 40 };
      }
      if (numId === 24) {
        return { x: 211.7, y: 620, w: 28.3, h: 40 };
      }
      if (numId === 25) {
        return { x: 240, y: 620, w: 40, h: 40 };
      }
      if (numId >= 26 && numId <= 31) {
        return { x: 280 + (numId - 26) * 40, y: 620, w: 40, h: 40 };
      }

      // Block R3 (Plots 32 to 38)
      if (numId === 32) return { x: 640, y: 620, w: 40, h: 40 };
      if (numId === 33) return { x: 680, y: 620, w: 40, h: 40 };
      if (numId === 34) return { x: 720, y: 620, w: 40, h: 40 };
      if (numId === 35) return { x: 760, y: 620, w: 30.7, h: 40 };
      if (numId === 36) return { x: 790.7, y: 620, w: 30.7, h: 40 };
      if (numId === 37) return { x: 821.3, y: 620, w: 30.7, h: 40 };
      if (numId === 38) return { x: 852, y: 620, w: 86, h: 33.3 };

      // Block L3 (Plots 47 to 62 & 54)
      if (numId >= 47 && numId <= 52) {
        return { x: 480 - (numId - 47) * 40, y: 510, w: 40, h: 40 };
      }
      if (numId === 53) {
        return { x: 248, y: 510, w: 32, h: 40 };
      }
      if (numId === 54) {
        return { x: 207.3, y: 510, w: 40.7, h: 40 };
      }
      if (numId === 55) {
        return { x: 198.3, y: 470, w: 49.7, h: 40 };
      }
      if (numId === 56) {
        return { x: 248, y: 470, w: 32, h: 40 };
      }
      if (numId >= 57 && numId <= 62) {
        return { x: 280 + (numId - 57) * 40, y: 470, w: 40, h: 40 };
      }

      // Block R4 (Plots 39 to 46, 63 to 71)
      if (numId >= 41 && numId <= 46) {
        return { x: 640 + (46 - numId) * 40, y: 510, w: 40, h: 40 };
      }
      if (numId === 40) {
        return { x: 880, y: 510, w: 36, h: 40 };
      }
      if (numId === 39) {
        return { x: 916, y: 510, w: 102.3, h: 40 };
      }
      if (numId >= 63 && numId <= 70) {
        return { x: 640 + (numId - 63) * 40, y: 470, w: 40, h: 40 };
      }
      if (numId === 71) {
        return { x: 960, y: 470, w: 45.3, h: 40 };
      }

      // Block L4 (Plots 82 to 93)
      if (numId >= 82 && numId <= 86) {
        return { x: 480 - (numId - 82) * 40, y: 370, w: 40, h: 40 };
      }
      if (numId === 87) {
        return { x: 280, y: 370, w: 40, h: 40 };
      }
      if (numId === 88) {
        return { x: 237.3, y: 370, w: 42.7, h: 40 };
      }
      if (numId === 89) {
        return { x: 179, y: 370, w: 58.3, h: 40 };
      }
      if (numId === 90) {
        return { x: 320, y: 330, w: 80, h: 40 };
      }
      if (numId >= 91 && numId <= 93) {
        return { x: 400 + (numId - 91) * 40, y: 330, w: 40, h: 40 };
      }

      // Block R5 (Plots 72 to 81, 94 to 104)
      if (numId >= 73 && numId <= 81) {
        return { x: 640 + (81 - numId) * 40, y: 370, w: 40, h: 40 };
      }
      if (numId === 72) {
        return { x: 1000, y: 370, w: 54, h: 40 };
      }
      if (numId >= 94 && numId <= 103) {
        return { x: 640 + (numId - 94) * 40, y: 330, w: 40, h: 40 };
      }
      if (numId === 104) {
        return { x: 1040, y: 330, w: 46.7, h: 40 };
      }

      // Block L5 (Plots 117 to 122)
      if (numId === 117) return { x: 480, y: 250, w: 40, h: 40 };
      if (numId === 118) return { x: 440, y: 250, w: 40, h: 40 };
      if (numId === 119) return { x: 370, y: 250, w: 70, h: 40 };
      if (numId === 120) return { x: 386.7, y: 210, w: 53.3, h: 40 };
      if (numId === 121) return { x: 440, y: 210, w: 40, h: 40 };
      if (numId === 122) return { x: 480, y: 210, w: 40, h: 40 };

      // Block R6 (Plots 106 to 116 & 123 to 144)
      if (numId >= 107 && numId <= 116) {
        return { x: 640 + (116 - numId) * 40, y: 250, w: 40, h: 40 };
      }
      if (numId === 106) {
        return { x: 1040, y: 250, w: 53, h: 40 };
      }
      if (numId === 123) {
        return { x: 640, y: 210, w: 40, h: 40 };
      }
      if (numId >= 124 && numId <= 142) {
        return { x: 680 + (numId - 124) * 20, y: 210, w: 20, h: 40 };
      }
      if (numId === 143) {
        return { x: 1060, y: 210, w: 18, h: 40 };
      }
      if (numId === 144) {
        return { x: 1078, y: 210, w: 15, h: 40 };
      }

      // Block L6 (Top Left, Plots 162 to 169 & Utilities)
      if (plotId === '169') return { x: 350, y: 100, w: 90, h: 80 };
      if (plotId === '168') return { x: 440, y: 40, w: 80, h: 140 };

      // Middle Block Column 1 (EB, 167, 166)
      if (plotId === 'EB') return { x: 640, y: -69, w: 130, h: 89.5 };
      if (plotId === '167') return { x: 640, y: 5.5, w: 130, h: 114.5 };
      if (plotId === '166') return { x: 640, y: 120, w: 130, h: 60 };

      // Middle Block Column 2 (LB, 162, 163, 164, 165)
      if (plotId === 'LB') return { x: 770, y: -69, w: 130, h: 27.5 };
      if (plotId === '162') return { x: 770, y: -41.5, w: 130, h: 30 };
      if (plotId === '163') return { x: 770, y: -11.5, w: 130, h: 30 };
      if (plotId === '164') return { x: 770, y: 18.5, w: 130, h: 30 };
      if (plotId === '165') return { x: 770, y: 48.5, w: 130, h: 131.5 };

      // Block R7 (Top Right, Plots 145 to 157)
      if (plotId === '157') return { x: 980, y: 48, w: 23, h: 90 };
      if (plotId === '156') return { x: 980, y: 138, w: 32.5, h: 42 };
      if (plotId === '155') return { x: 1003, y: 102.5, w: 53, h: 77.5 };
      if (plotId === '154') return { x: 1052.5, y: 106, w: 44, h: 74 };
      if (plotId === '153') return { x: 1092.5, y: 106, w: 44, h: 74 };
      if (plotId === '152') return { x: 1132.5, y: 104, w: 44, h: 76 };
      if (plotId === '151') return { x: 1172.5, y: 104, w: 44, h: 76 };
      if (plotId === '150') return { x: 1212.5, y: 102, w: 44, h: 78 };
      if (plotId === '149') return { x: 1252.5, y: 99, w: 44.5, h: 81 };
      if (plotId === '148') return { x: 1292.5, y: 99, w: 43.5, h: 81 };
      if (plotId === '147') return { x: 1332.5, y: 100, w: 42.5, h: 80 };
      if (plotId === '146') return { x: 1372.5, y: 102.5, w: 35.5, h: 77.5 };
      if (plotId === '145') return { x: 1405, y: 104.5, w: 33, h: 75.5 };

      return null;
    };

    const coords = getBaseCoords();
    if (!coords) return null;

    const numId = parseInt(plotId, 10);
    const isR7Block = numId >= 145 && numId <= 157;
    const isR6Block = (numId >= 106 && numId <= 116) || (numId >= 123 && numId <= 144);
    const isR4R5Block = (numId >= 39 && numId <= 46) || (numId >= 63 && numId <= 71) || (numId >= 72 && numId <= 81) || (numId >= 94 && numId <= 104);

    const isColumn1 = (plotId === 'EB' || plotId === '167' || plotId === '166');
    const isColumn2 = (plotId === 'LB' || plotId === '162' || plotId === '163' || plotId === '164' || plotId === '165');
    const isLeftPlots = (plotId === '168' || plotId === '169');

    // Apply X scaling:
    let x = coords.x;
    let w = coords.w;
    if (isLeftPlots) {
      x = 520 - (520 - x) * 0.8;
      w = w * 0.8;
    } else if (isColumn1 || isColumn2) {
      x = 640 + (x - 640) * (90 / 130);
      w = w * (90 / 130);
    } else if (isR7Block) {
      x = 980 + (x - 980) * 0.75;
      w = w * 0.75;
    }

    // Apply X shift:
    if (x >= 640) {
      x -= 80; // shift all right-side plots left by 80px (for 33'0" road narrowing from 120px to 40px)
    }

    // Shift right-side plots next to middle vertical road
    if (coords.x >= 980 && (isR4R5Block || isR6Block)) {
      x -= 40; // Shift left by an additional 40px (total 120px shift, due to middle vertical road narrowing from 80px to 40px)
    }
    if (isR7Block) {
      x -= 120; // Shift left by an additional 120px (total 200px shift)
    }

    // Apply Y shift:
    let y = coords.y;
    let yOffset = 200; // default for Row 1

    const isRow6 = (numId >= 1 && numId <= 9);
    const isRow5 = (numId >= 16 && numId <= 38);
    const isRow4 = (numId >= 47 && numId <= 62) || (numId >= 39 && numId <= 46) || (numId >= 63 && numId <= 71);
    const isRow3 = (numId >= 82 && numId <= 93) || (numId >= 72 && numId <= 81) || (numId >= 94 && numId <= 104);
    const isRow2 = (numId >= 117 && numId <= 122) || (numId >= 106 && numId <= 116) || (numId >= 123 && numId <= 144);

    if (isRow6) {
      yOffset = 60;
    } else if (isRow5) {
      yOffset = 160;
    } else if (isRow4) {
      yOffset = 190;
    } else if (isRow3) {
      yOffset = 210;
    } else if (isRow2) {
      yOffset = 210;
    }

    return { x, y: y + yOffset, w, h: coords.h };
  };

  // Helper to get exact color of plot as shown in physical layout sheet
  const getPlotColor = (plotId: string): string => {
    const numId = parseInt(plotId, 10);

    if (plotId === 'EB') return '#90caf9'; // Light Blue
    if (plotId === 'LB') return '#a5d6a7'; // Light Green

    // Block L1 (1-7)
    if (numId === 1 || numId === 7) return '#f8bbd0'; // Pink
    if (numId >= 2 && numId <= 6) return '#fff176'; // Yellow

    // Block R1 (8-9) -> Yellow
    if (numId === 8 || numId === 9) return '#fff176';

    // Block R2 (10-15) -> Pink
    if (numId >= 10 && numId <= 15) return '#f8bbd0';

    // Block L2 (16-31)
    if (numId >= 16 && numId <= 24) return '#f8bbd0'; // Pink
    if (numId >= 25 && numId <= 30) return '#fff176'; // Yellow
    if (numId === 31) return '#f8bbd0'; // Pink

    // Block R3 (32-38) -> Yellow
    if (numId >= 32 && numId <= 38) return '#fff176';

    // Block R4 (39-46 & 63-71)
    if (numId >= 39 && numId <= 46) return '#ffb74d'; // Orange
    if (numId >= 63 && numId <= 71) return '#fff176'; // Yellow

    // Block L3 (47-53, 54 & 55-62)
    if (numId >= 47 && numId <= 54) return '#f28b82'; // Red-pink
    if (numId >= 55 && numId <= 62) return '#fff176'; // Yellow

    // Block L4 (82-89 & 90-93)
    if (numId >= 82 && numId <= 89) return '#f8bbd0'; // Pink
    if (numId >= 90 && numId <= 93) return '#fff176'; // Yellow

    // Block R5 (72-81 & 94-104)
    if (numId >= 72 && numId <= 81) return '#f8bbd0'; // Pink
    if (numId >= 94 && numId <= 104) return '#fff176'; // Yellow

    // Block L5 (117-118 & 119-122)
    if (numId === 117 || numId === 118) return '#f28b82'; // Red-pink
    if (numId >= 119 && numId <= 122) return '#fff176'; // Yellow

    // Block R6 (106-116 & 123-144)
    if (numId >= 106 && numId <= 116) return '#f8bbd0'; // Pink
    if (numId >= 123 && numId <= 144) return '#fff176'; // Yellow

    // Block L6 (162-166 & 167-169)
    if (numId >= 162 && numId <= 166) return '#f28b82'; // Red-pink
    if (numId >= 167 && numId <= 169) return '#ffb74d'; // Orange

    // Block R7 (145-157) -> Red/Pink
    if (numId >= 145 && numId <= 157) return '#f28b82';

    return '#fff176'; // default fallback
  };

  return (
    <div className="w-full h-full overflow-hidden select-none flex items-center justify-center bg-[#e6f2ec]">
      <svg
        viewBox="0 0 1540 1180"
        width="1540"
        height="1180"
        style={{
          maxWidth: '100%',
          maxHeight: '100%',
          width: 'auto',
          height: 'auto',
          display: 'block',
        }}
      >
        {/* Grid and Hatching Patterns */}
        <defs>
          <pattern id="grid" width="40" height="40" patternUnits="userSpaceOnUse">
            <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(0,0,0,0.03)" strokeWidth="1" />
          </pattern>
          <pattern id="booked-pattern" width="8" height="8" patternTransform="rotate(45 0 0)" patternUnits="userSpaceOnUse">
            <line x1="0" y1="0" x2="0" y2="8" stroke="#ef4444" strokeWidth="1.5" opacity="0.6" />
          </pattern>
          <pattern id="blocked-pattern" width="8" height="8" patternTransform="rotate(45 0 0)" patternUnits="userSpaceOnUse">
            <line x1="0" y1="0" x2="0" y2="8" stroke="#f59e0b" strokeWidth="1.5" opacity="0.6" />
          </pattern>
        </defs>
        <rect width="1540" height="1180" fill="url(#grid)" />


        {/* ======================================================== */}
        {/* 1. TOP NATIONAL HIGHWAY (NH-ROAD)                         */}
        {/* ======================================================== */}
        <g>
          {/* Asphalt NH Road */}
          <rect x="0" y="0" width="1540" height="75" fill="#1b211e" stroke="#2a332e" strokeWidth="2" />

          {/* White highway shoulders */}
          <line x1="0" y1="2" x2="1540" y2="2" stroke="#e2e8f0" strokeWidth="2" opacity="0.8" />
          <line x1="0" y1="73" x2="1540" y2="73" stroke="#e2e8f0" strokeWidth="2" opacity="0.8" />

          {/* Yellow middle highway lanes separator */}
          <line x1="0" y1="37" x2="1540" y2="37" stroke="#eab308" strokeWidth="2" strokeDasharray="30, 20" />

          {/* NH Road Text */}
          <text x="770" y="44" className="fill-white font-display font-extrabold text-[16px] tracking-[0.25em]" textAnchor="middle">
            MADURAI - CHENNAI NH ROAD
          </text>

          {/* Small moving vehicles for premium animated wow-factor! */}
          <g className="car-bus animate-drive-left">
            {/* Bus */}
            <rect x="300" y="10" width="45" height="15" rx="3" fill="#3b82f6" />
            <rect x="305" y="12" width="8" height="11" fill="#93c5fd" />
            <rect x="333" y="12" width="10" height="11" fill="#93c5fd" />
            <circle cx="310" cy="25" r="2.5" fill="#000" />
            <circle cx="335" cy="25" r="2.5" fill="#000" />
          </g>
          <g className="car-bus animate-drive-right">
            {/* Car */}
            <rect x="100" y="48" width="28" height="12" rx="2" fill="#ef4444" />
            <rect x="115" y="50" width="8" height="8" fill="#fca5a5" />
            <circle cx="106" cy="60" r="2" fill="#000" />
            <circle cx="122" cy="60" r="2" fill="#000" />
          </g>
        </g>

        {/* ======================================================== */}
        {/* 2. INTERNAL ROADS AND PATHWAYS                          */}
        {/* ======================================================== */}
        <g>
          {/* Main Center Vertical Road (33'0" Road) */}
          <rect x="520" y="275" width="40" height="905" fill="#1b211e" stroke="#252b27" strokeWidth="0.5" />
          <line x1="540" y1="275" x2="540" y2="1180" stroke="#ffffff" strokeWidth="1.5" strokeDasharray="15, 10" opacity="0.3" />

          {/* Main center vertical road is labeled 33'0" ROAD */}
          <text x="540" y="770" transform="rotate(-90 540 770)" className="road-text text-[10px]" fill="rgba(255,255,255,0.7)" textAnchor="middle">
            33'0" ROAD
          </text>

          {/* New Middle Vertical Road (23'9" Road) */}
          <rect x="740" y="275" width="40" height="105" fill="#1b211e" stroke="#252b27" strokeWidth="0.5" />
          <text x="760" y="330" transform="rotate(-90 760 330)" className="road-text text-[9px]" fill="rgba(255,255,255,0.7)" textAnchor="middle">
            23'9" ROAD
          </text>

          {/* Existing Road Left Slanted/Vertical */}
          <polygon points="100,275 150,275 179,580 198.3,660 211.7,780 220,820 230.7,900 240.3,971.7 235,1180 185,1180 190.3,971.7 180.7,900 170,820 161.7,780 148.3,660 129,580 100,275" fill="#1b211e" />
          <text x="205" y="940" transform="rotate(-82 205 940)" className="road-text text-[9px]">
            EXISTING ROAD
          </text>

          {/* Horizontal Roads */}
          {/* 23'9" Road - Row 6/7 Top */}
          <rect x="0" y="380" width="1540" height="40" fill="#1b211e" />
          <text x="260" y="399" className="road-text text-[9px]">23'9" ROAD</text>
          <text x="814" y="399" className="road-text text-[9px]">23'9" ROAD</text>

          {/* 23'9" Road - Bottom */}
          <rect x="0" y="860" width="1540" height="40" fill="#1b211e" />
          <line x1="0" y1="880" x2="1540" y2="880" stroke="#ffffff" strokeWidth="1.5" strokeDasharray="15, 10" opacity="0.3" />
          <text x="260" y="884" className="road-text text-[10px]" fill="#ffffff" opacity="0.8" fontWeight="bold" textAnchor="middle">23'9" ROAD</text>
          <text x="814" y="884" className="road-text text-[10px]" fill="#ffffff" opacity="0.8" fontWeight="bold" textAnchor="middle">23'9" ROAD</text>

          {/* 29'6" Roads in between */}
          {/* 29'6" Road - Middle Top */}
          <rect x="0" y="500" width="1540" height="40" fill="#1b211e" />
          <text x="260" y="523" className="road-text text-[9px]">29'6" ROAD</text>
          <text x="688" y="523" className="road-text text-[10px]" fill="#ffffff" opacity="0.8" fontWeight="bold" textAnchor="middle">29'6" ROAD</text>
          <text x="814" y="523" className="road-text text-[9px]">29'6" ROAD</text>

          {/* 29'6" Road - Mid Middle */}
          <rect x="0" y="620" width="1540" height="40" fill="#1b211e" />
          <text x="260" y="643" className="road-text text-[9px]">29'6" ROAD</text>
          <text x="688" y="643" className="road-text text-[10px]" fill="#ffffff" opacity="0.8" fontWeight="bold" textAnchor="middle">29'6" ROAD</text>
          <text x="814" y="643" className="road-text text-[9px]">29'6" ROAD</text>

          {/* 29'6" Road - Middle Bottom */}
          <rect x="0" y="740" width="1540" height="40" fill="#1b211e" />
          <text x="260" y="763" className="road-text text-[9px]">29'6" ROAD</text>
          <text x="688" y="763" className="road-text text-[10px]" fill="#ffffff" opacity="0.8" fontWeight="bold" textAnchor="middle">29'6" ROAD</text>
          <text x="814" y="763" className="road-text text-[9px]">29'6" ROAD</text>

          {/* Blue Survey Lines */}
          <line x1="610" y1="514" x2="744" y2="734" stroke="#1d4ed8" strokeWidth="1" strokeDasharray="5,3" opacity="0.7" />
          <line x1="828" y1="482" x2="620" y2="762" stroke="#1d4ed8" strokeWidth="1" strokeDasharray="5,3" opacity="0.7" />
          <line x1="416" y1="210" x2="350" y2="494" stroke="#1d4ed8" strokeWidth="1" strokeDasharray="5,3" opacity="0.7" />
          <line x1="165" y1="597" x2="280" y2="734" stroke="#1d4ed8" strokeWidth="1" strokeDasharray="5,3" opacity="0.7" />
          <line x1="530" y1="734" x2="440" y2="804" stroke="#1d4ed8" strokeWidth="1" strokeDasharray="5,3" opacity="0.7" />
