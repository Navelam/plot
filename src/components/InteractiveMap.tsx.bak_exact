                labels.push(<text key="right" x={245} y={690} transform="rotate(-90 245 690)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
                labels.push(<text key="left-slant" x={205} y={690} transform="rotate(-57 205 690)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>44'6"</text>);
              } else if (numId === 56) {
                points = "248,670 280,670 280,710 248,710";
                textX = 264; textY = 690;
                labels.push(<text key="top" x={264} y={678} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>24'</text>);
                labels.push(<text key="bottom" x={264} y={706} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>24'</text>);
                labels.push(<text key="right" x={277} y={690} transform="rotate(-90 277 690)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId >= 57 && numId <= 62) {
                const idx = numId - 57;
                const xStart = 280 + idx * 40;
                const xEnd = xStart + 40;
                points = `${xStart},670 ${xEnd},670 ${xEnd},710 ${xStart},710`;
                textX = xStart + 20; textY = 690;
                labels.push(<text key="top" x={xStart + 20} y={678} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="bottom" x={xStart + 20} y={706} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="right" x={xEnd - 3} y={690} transform={`rotate(-90 ${xEnd - 3} 690)`} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              }

              return (
                <g key={plot.id} onClick={() => onSelectPlot(plot)} transform={`translate(0, ${ty})`}>
                  {isSelected && (
                    <polygon
                      points={points}
                      fill="none"
                      stroke="#0d9488"
                      strokeWidth="2.5"
                      style={{ filter: 'drop-shadow(0 0 8px rgba(13,148,136,0.5))' }}
                    />
                  )}
                  <polygon
                    points={points}
                    fill={originalColor}
                    stroke="#2c3e50"
                    strokeWidth="1"
                    className="plot-rect"
                  />
                  {plot.status === 'booked' && !isUtility && (
                    <polygon
                      points={points}
                      fill="url(#booked-pattern)"
                      stroke="#ef4444"
                      strokeWidth="1.5"
                      pointerEvents="none"
                    />
                  )}
                  {plot.status === 'blocked' && !isUtility && (
                    <polygon
                      points={points}
                      fill="url(#blocked-pattern)"
                      stroke="#f59e0b"
                      strokeWidth="1.5"
                      pointerEvents="none"
                    />
                  )}
                  <text
                    x={textX}
                    y={textY}
                    transform={`rotate(-90 ${textX} ${textY})`}
                    className="plot-text"
                    style={{
                      fill: isSelected ? '#000000' : '#ef5350',
                      fontWeight: 'bold',
                      fontSize: '11px',
                      textAnchor: 'middle'
                    }}
                  >
                    {plot.id}
                  </text>
                  {labels}
                </g>
              );
            }

            const isR4R5Block = (numId >= 39 && numId <= 46) || (numId >= 63 && numId <= 71) || (numId >= 72 && numId <= 81) || (numId >= 94 && numId <= 104);
            if (isR4R5Block) {
              const isRow4 = (numId >= 39 && numId <= 46) || (numId >= 63 && numId <= 71);
              const ty = isRow4 ? -10 : 10;
              const tx = (numId === 72 || numId === 103 || numId === 104) ? -120 : -80;
              let points = '';
              let labels: React.ReactNode[] = [];
              let textX = 0;
              let textY = 0;

              if (numId === 94) {
                points = "650,530 680,530 680,570 640,570 640,540";
                textX = 660; textY = 550;
                labels.push(<text key="top" x={665} y={538} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="bottom" x={660} y={566} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="left" x={646} y={555} transform="rotate(-90 646 555)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId >= 95 && numId <= 103) {
                const idx = numId - 94;
                const xStart = 640 + idx * 40;
                const xEnd = xStart + 40;
                points = `${xStart},530 ${xEnd},530 ${xEnd},570 ${xStart},570`;
                textX = xStart + 20; textY = 550;
                labels.push(<text key="top" x={xStart + 20} y={538} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="bottom" x={xStart + 20} y={566} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="right" x={xEnd - 3} y={550} transform={`rotate(-90 ${xEnd - 3} 550)`} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId === 104) {
                points = "1040,530 1086.7,530 1053.3,570 1040,570";
                textX = 1052; textY = 550;
                labels.push(<text key="top" x={1063} y={538} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>35'</text>);
                labels.push(<text key="bottom" x={1046} y={566} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>10'</text>);
                labels.push(<text key="right" x={1073} y={548} transform="rotate(-50 1073 548)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>48'3"</text>);
              } else if (numId === 81) {
                points = "640,570 680,570 680,610 650,610 640,600";
                textX = 660; textY = 590;
                labels.push(<text key="bottom" x={665} y={606} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="left" x={646} y={588} transform="rotate(-90 646 588)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId >= 73 && numId <= 80) {
                const idx = 81 - numId;
                const xStart = 640 + idx * 40;
                const xEnd = xStart + 40;
                points = `${xStart},570 ${xEnd},570 ${xEnd},610 ${xStart},610`;
                textX = xStart + 20; textY = 590;
                labels.push(<text key="bottom" x={xStart + 20} y={606} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                if (numId % 2 !== 0) {
                  labels.push(<text key="top" x={xStart + 20} y={578} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                }
                labels.push(<text key="right" x={xEnd - 3} y={590} transform={`rotate(-90 ${xEnd - 3} 590)`} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId === 72) {
                points = "1000,570 1053.5,570 1022.7,610 1000,610";
                textX = 1018; textY = 590;
                labels.push(<text key="bottom" x={1010} y={606} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>17'</text>);
                labels.push(<text key="top" x={1032} y={578} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>40'6"</text>);
                labels.push(<text key="right" x={1042} y={588} transform="rotate(-52 1042 588)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>27'9"</text>);
              } else if (numId === 63) {
                points = "650,670 680,670 680,710 640,710 640,680";
                textX = 660; textY = 690;
                labels.push(<text key="top" x={665} y={678} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="bottom" x={660} y={706} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="left" x={646} y={695} transform="rotate(-90 646 695)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId >= 64 && numId <= 70) {
                const idx = numId - 63;
                const xStart = 640 + idx * 40;
                const xEnd = xStart + 40;
                points = `${xStart},670 ${xEnd},670 ${xEnd},710 ${xStart},710`;
                textX = xStart + 20; textY = 690;
                labels.push(<text key="top" x={xStart + 20} y={678} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="bottom" x={xStart + 20} y={706} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="right" x={xEnd - 3} y={690} transform={`rotate(-90 ${xEnd - 3} 690)`} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId === 71) {
                points = "960,670 1005.3,670 978.3,710 960,710";
                textX = 974; textY = 690;
                labels.push(<text key="top" x={982} y={678} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>34'</text>);
                labels.push(<text key="bottom" x={968} y={706} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>13'9"</text>);
                labels.push(<text key="right" x={995} y={688} transform="rotate(-56 995 688)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>45'3"</text>);
              } else if (numId === 46) {
                points = "640,710 680,710 680,750 650,750 640,740";
                textX = 660; textY = 730;
                labels.push(<text key="bottom" x={665} y={746} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                labels.push(<text key="left" x={646} y={728} transform="rotate(-90 646 728)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId >= 41 && numId <= 45) {
                const idx = 46 - numId;
                const xStart = 640 + idx * 40;
                const xEnd = xStart + 40;
                points = `${xStart},710 ${xEnd},710 ${xEnd},750 ${xStart},750`;
                textX = xStart + 20; textY = 730;
                labels.push(<text key="bottom" x={xStart + 20} y={746} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                if (numId % 2 !== 0) {
                  labels.push(<text key="top" x={xStart + 20} y={718} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>30'</text>);
                }
                labels.push(<text key="right" x={xEnd - 3} y={730} transform={`rotate(-90 ${xEnd - 3} 730)`} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId === 40) {
                points = "880,710 916,710 916,750 880,750";
                textX = 898; textY = 730;
                labels.push(<text key="top" x={898} y={718} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>27'</text>);
                labels.push(<text key="bottom" x={898} y={746} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>27'</text>);
                labels.push(<text key="right" x={913} y={730} transform="rotate(-90 913 730)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px' }}>41'</text>);
              } else if (numId === 39) {
                points = "916,710 978.3,710 951.7,750 916,750";
                textX = 938; textY = 730;
                labels.push(<text key="top" x={947} y={718} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>46'9"</text>);
                labels.push(<text key="bottom" x={933} y={746} className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>26'9"</text>);
                labels.push(<text key="right" x={968} y={728} transform="rotate(-56 968 728)" className="plot-label-sub" style={{ fill: '#000000', fontSize: '6.5px', textAnchor: 'middle' }}>46'</text>);
              }

              return (
                <g key={plot.id} onClick={() => onSelectPlot(plot)} transform={`translate(${tx}, ${ty})`}>
                  {isSelected && (
                    <polygon
                      points={points}
                      fill="none"
                      stroke="#0d9488"
                      strokeWidth="2.5"
                      style={{ filter: 'drop-shadow(0 0 8px rgba(13,148,136,0.5))' }}
                    />
                  )}
                  <polygon
                    points={points}
                    fill={originalColor}
                    stroke="#2c3e50"
                    strokeWidth="1"
                    className="plot-rect"
                  />
                  {plot.status === 'booked' && !isUtility && (
                    <polygon
                      points={points}
                      fill="url(#booked-pattern)"
                      stroke="#ef4444"
                      strokeWidth="1.5"
                      pointerEvents="none"
                    />
                  )}
                  {plot.status === 'blocked' && !isUtility && (
                    <polygon
                      points={points}
                      fill="url(#blocked-pattern)"
                      stroke="#f59e0b"
                      strokeWidth="1.5"
                      pointerEvents="none"
                    />
                  )}
                  <text
                    x={textX}
                    y={textY}
                    transform={`rotate(-90 ${textX} ${textY})`}
                    className="plot-text"
                    style={{
                      fill: isSelected ? '#000000' : '#ef5350',
                      fontWeight: 'bold',
                      fontSize: '11px',
                      textAnchor: 'middle'
                    }}
                  >
                    {plot.id}
                  </text>
                  {labels}
                </g>
              );
            }

            return (
              <g key={plot.id} onClick={() => onSelectPlot(plot)}>
                {/* Outer glow/highlight if selected */}
                {isSelected && (
                  <rect
                    x={coords.x - 3}
                    y={coords.y - 3}
                    width={coords.w + 6}
                    height={coords.h + 6}
                    fill="none"
                    stroke="#0d9488"
                    strokeWidth="2.5"
                    rx="3"
                    style={{ filter: 'drop-shadow(0 0 8px rgba(13,148,136,0.5))' }}
                  />
                )}

                {/* The Base Plot shape with original layout color */}
                <rect
                  x={coords.x}
                  y={coords.y}
                  width={coords.w}
                  height={coords.h}
                  rx="1"
                  fill={originalColor}
                  stroke="#2c3e50"
                  strokeWidth="1"
                  className="plot-rect"
                />

                {/* Booking / Blocked Overlay Patterns */}
                {plot.status === 'booked' && !isUtility && (
                  <rect
                    x={coords.x}
                    y={coords.y}
                    width={coords.w}
                    height={coords.h}
                    rx="1"
                    fill="url(#booked-pattern)"
                    stroke="#ef4444"
                    strokeWidth="1.5"
                    pointerEvents="none"
                  />
                )}

                {plot.status === 'blocked' && !isUtility && (
                  <rect
                    x={coords.x}
                    y={coords.y}
                    width={coords.w}
                    height={coords.h}
                    rx="1"
                    fill="url(#blocked-pattern)"
                    stroke="#f59e0b"
                    strokeWidth="1.5"
                    pointerEvents="none"
                  />
                )}

                {/* Plot Text Label */}
                <text
                  x={coords.x + coords.w / 2}
                  y={coords.y + coords.h / 2}
                  className={`plot-text ${isUtility ? 'utility-label' : ''}`}
                  style={{
                    fill: isSelected ? '#000000' : (isUtility ? '#1e293b' : '#ef5350'),
                    fontWeight: 'bold',
                    fontSize: coords.w < 25 ? '7px' : '9px'
                  }}
                >
                  {plot.id}
                </text>

                {/* Extra layout dimensions details inside the plot */}
                {coords.w >= 45 && coords.h >= 40 && !isUtility && (
                  <text
                    x={coords.x + coords.w / 2}
                    y={coords.y + coords.h / 2 + 13}
                    className="plot-label-sub"
                  >
                    {plot.dimensions.split(' ')[0]}
                  </text>
                )}
              </g>
            );
          })}
        </g>

        {/* ======================================================== */}
        {/* 5. METADATA AND GRAPHICS (DTCP, COMPASS)                  */}
        {/* ======================================================== */}
        <g>
          {/* DTCP Stamp (Moved to Right Empty Space next to Plan card) */}
          <g transform="translate(860, 85)" className="compass-rose">
            <polygon points="50,0 100,30 100,90 50,120 0,90 0,30" fill="#ffffff" stroke="#ef5350" strokeWidth="2" />
            <circle cx="50" cy="60" r="38" fill="none" stroke="#ef5350" strokeWidth="1.5" strokeDasharray="4,2" />
            <text x="50" y="42" className="fill-[#ef5350] font-display font-black text-[12px]" textAnchor="middle">DTCP</text>
            <text x="50" y="58" className="fill-[#ef5350] font-sans font-bold text-[8px]" textAnchor="middle">APPROVED</text>
            <text x="50" y="70" className="fill-[#ef5350] font-sans font-extrabold text-[8px]" textAnchor="middle">69/2026</text>
            <text x="50" y="82" className="fill-[#ef5350] font-sans font-semibold text-[7px]" textAnchor="middle">LAYOUT</text>
          </g>

          {/* Compass Rose */}
          <g transform="translate(1340, 680)">
            {/* Outer compass ring */}
            <circle cx="50" cy="50" r="45" fill="#ffffff" stroke="#2c3e50" strokeWidth="1.5" />
            <circle cx="50" cy="50" r="40" fill="none" stroke="#2c3e50" strokeWidth="1" strokeDasharray="3, 3" opacity="0.3" />

            {/* Compass needles */}
            <polygon points="50,12 55,50 50,45" fill="#ef4444" /> {/* North */}
            <polygon points="50,12 45,50 50,45" fill="#b91c1c" />

            <polygon points="50,88 55,50 50,55" fill="#2c3e50" /> {/* South */}
            <polygon points="50,88 45,50 50,55" fill="#1e293b" />

            <polygon points="88,50 50,55 50,50" fill="#2c3e50" /> {/* East */}
            <polygon points="88,50 50,45 50,50" fill="#1e293b" />

            <polygon points="12,50 50,55 50,50" fill="#2c3e50" /> {/* West */}
            <polygon points="12,50 50,45 50,50" fill="#1e293b" />

            {/* Text labels */}
            <text x="50" y="8" className="fill-[#ef4444] font-display font-black text-[11px]" textAnchor="middle">N</text>
            <text x="50" y="98" className="fill-[#2c3e50] font-display font-bold text-[9px]" textAnchor="middle">S</text>
            <text x="96" y="53" className="fill-[#2c3e50] font-display font-bold text-[9px]">E</text>
            <text x="4" y="53" className="fill-[#2c3e50] font-display font-bold text-[9px]">W</text>
          </g>
        </g>
      </svg>
    </div>
  );
};
